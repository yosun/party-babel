# ── STT Engine ────────────────────────────────────────────
STT_ENGINE=transformers          # transformers | vllm
VOXTRAL_MODEL_ID=mistralai/Voxtral-Mini-4B-Realtime-2602
TRANSCRIPTION_DELAY_MS=480       # micro-batch interval
VLLM_REALTIME_URL=http://localhost:8000/v1/realtime

# ── Mistral API (optional, replaces local STT + translation) ─
MISTRAL_API_KEY=                 # set to use Mistral cloud API
MISTRAL_API_URL=https://api.mistral.ai

# ── Translation ───────────────────────────────────────────
LOCAL_LLM_URL=                   # optional OpenAI-compatible endpoint

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://party:party@localhost:5432/party_babel

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-me

# ── Server ────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# ── Redis (optional) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379
